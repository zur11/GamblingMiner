; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="GamblingMiner"
run/main_scene="res://Screens/MainMenu/MainMenu.tscn"
config/features=PackedStringArray("4.5", "C#", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

UserStatsService="*res://Scripts/Services/UserStatsService.cs"
CalendarTimeService="*res://Scripts/Services/CalendarTimeService.cs"
BankrollStateService="*res://Scripts/Services/BankrollStateService.cs"
PrincipalBalanceService="*res://Scripts/Services/PrincipalBalanceService.cs"
BankrollProgramService="*res://Scripts/Services/BankrollProgramService.cs"
CasinoScBalanceService="*res://Scripts/Services/CasinoScBalanceService.cs"
BlockSessionCheckpointService="*res://Scripts/Services/BlockSessionCheckpointService.cs"
SceneManager="*res://Scripts/Services/SceneManager.cs"
NotepadService="*res://Scripts/Services/NotepadService.cs"
FoundersMiningService="*res://Scripts/Services/FoundersMiningService.cs"
SimulationService="*res://Scripts/Services/SimulationService.cs"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="GamblingMiner"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
